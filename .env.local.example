# Copy this file to .env.local and fill in your own values.
# Get these from your Supabase project: Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: set a shared passcode so only you two can open the app.
# Leave blank to skip the lock screen entirely.
NEXT_PUBLIC_APP_PASSCODE=choose-a-passcode
